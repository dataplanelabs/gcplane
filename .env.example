# GoClaw connection (gateway token from goclaw .env)
GOCLAW_TOKEN=

# Z.ai Coding provider
GOCLAW_ZAI_CODING_API_KEY=

# Drift notification webhook (slack, discord, googlechat, teams, telegram)
GCPLANE_WEBHOOK_URL=
GCPLANE_WEBHOOK_FORMAT=slack

# Structured logging (text or json)
GCPLANE_LOG_FORMAT=text
